# Frontend-only environment variables
VITE_API_URL=http://localhost:8888
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
VITE_STRIPE_PRODUCT_ID=your_product_id
VITE_STRIPE_PRICE_ID=your_price_id
VITE_STRIPE_SUCCESS_URL=http://localhost:5173/dashboard
VITE_STRIPE_CANCEL_URL=http://localhost:5173/pricing

# Backend environment variables (for Netlify functions)
FRONTEND_URL=http://localhost:5173

# Note: The following secrets should be moved to backend environment:
# - STRIPE_SECRET_KEY
# - STRIPE_WEBHOOK_SECRET
# - GOOGLE_APPLICATION_CREDENTIALS

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
